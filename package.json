{
  "name": "@construct-space/ui",
  "version": "0.3.2",
  "description": "Construct UI — Vue 3 component library for Construct services",
  "type": "module",
  "main": "./dist/construct-ui.js",
  "module": "./dist/construct-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/construct-ui.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "construct",
    "ui",
    "vue",
    "components",
    "design-system"
  ],
  "homepage": "https://github.com/construct-space/ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/construct-space/ui.git"
  },
  "license": "MIT",
  "author": {
    "name": "Construct Team"
  },
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "prepublishOnly": "bun run build",
    "release": "bun run build && npm publish"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "reka-ui": "^2.0.0",
    "@iconify/vue": "^4.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@iconify/vue": "^4.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "reka-ui": "^2.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^8.0.0",
    "vue": "^3.5.28",
    "vue-tsc": "^2.0.0"
  }
}
